# Smart Chatbot - Environment Variables
# Copy this file to .env and fill in your values

# ============ N8N ============
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=your_secure_password
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678

# ============ DATABASE ============
POSTGRES_USER=n8n
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=n8n

# ============ REDIS ============
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# ============ NEO4J ============
NEO4J_AUTH=neo4j/your_neo4j_password
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# ============ AI/LLM ============
GOOGLE_API_KEY=your_gemini_api_key
OPENAI_API_KEY=your_openai_api_key_optional

# ============ FACEBOOK ============
FB_VERIFY_TOKEN=your_verify_token
FB_PAGE_ACCESS_TOKEN=your_page_access_token
FB_APP_SECRET=your_app_secret
# Multiple admin PSIDs separated by comma
FB_ADMIN_PSIDS=admin1_psid,admin2_psid,admin3_psid

# ============ ZALO ============
ZALO_OA_ID=your_oa_id
ZALO_OA_SECRET=your_oa_secret
ZALO_ACCESS_TOKEN=your_access_token
ZALO_REFRESH_TOKEN=your_refresh_token
ZALO_APP_ID=your_app_id
ZALO_ZNS_TEMPLATE_ID=your_template_id
ZALO_GROUP_LINK=https://zalo.me/g/your_group

# ============ TELESALE ============
TELESALE_PHONES=0901234567,0912345678

# ============ TELEGRAM (Free alternative to Zalo ZNS) ============
# Create bot with @BotFather, add to group, get chat_id
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_or_group_id

# ============ CHATBOT CONFIG ============
# Standard debounce for regular messages
DEBOUNCE_SECONDS=7
# Quick debounce for messages ending with ? (complete questions)
DEBOUNCE_QUICK_SECONDS=3
ADMIN_HANDOVER_MINUTES=30
FOLLOWUP_HOURS=24
MAX_FOLLOWUPS=3

# ============ FEATURE TOGGLES (Demo Mode) ============
# Set to false to save cost during demo/testing
ENABLE_ZALO_ZNS=false
# Use Telegram instead of Zalo for lead notifications (free)
ENABLE_TELEGRAM_NOTIFY=true
